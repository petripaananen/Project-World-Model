# PWM Environment Configuration
# Copy this file to .env and fill in your values

# ── Gemini API Access ──────────────────────────────────────
# Option 1: Google AI Studio key (simplest)
GOOGLE_API_KEY=

# Option 2: Google Cloud / Vertex AI
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# ── GitHub Ingestion ────────────────────────────────────────
PWM_GITHUB_OWNER=
PWM_GITHUB_REPO=
GITHUB_PERSONAL_ACCESS_TOKEN=  # Required for github-mcp-server

# ── Linear Ingestion ───────────────────────────────────────
PWM_LINEAR_TEAM_ID=
LINEAR_API_KEY=                # Required for linear-mcp-server
